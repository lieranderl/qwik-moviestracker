{
  "name": "moviestracker",
  "description": "Moviestracker",
  "engines": {
    "node": "^20.3.0 || >=21.0.0"
  },
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
  "private": true,
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "sharp"
  ],
  "trustedDependencies-annotation": "Needed for bun to allow running install scripts",
  "overrides": {
    "@typescript-eslint/typescript-estree": "8.63.0",
    "@typescript-eslint/utils": "8.63.0",
    "cross-spawn": "7.0.6",
    "flatted": "3.4.2",
    "minimatch": "10.2.4",
    "picomatch": "4.0.5",
    "rollup": "4.59.1",
    "shell-quote": "1.9.0",
    "svgo": "3.3.3"
  },
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "vite build -c adapters/bun/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "deploy": "echo 'Production deploys run through .github/workflows/deploy.yml on published GitHub releases'",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "preview": "qwik build preview && vite preview --open",
    "serve": "bun server/entry.bun.js",
    "start": "vite --open --mode ssr",
    "test": "bun test",
    "test:e2e": "playwright test -c playwright.config.mjs",
    "test:e2e:smoke": "playwright test -c playwright.config.mjs tests/e2e/auth-guard.pw.ts tests/e2e/authenticated-shell.pw.ts",
    "verify": "bun run build.types && bun run lint && bun run test && bun run build",
    "biome": "biome check --fix",
    "qwik": "qwik"
  },
  "dependencies": {
    "@auth/mongodb-adapter": "^3.11.2",
    "mongodb": "6.21.0",
    "undici": "8.7.0",
    "valibot": "1.4.2"
  },
  "devDependencies": {
    "@auth/qwik": "^0.9.2",
    "@biomejs/biome": "^2.5.3",
    "@builder.io/qwik": "^1.20.0",
    "@builder.io/qwik-city": "^1.20.0",
    "@catppuccin/daisyui": "^2.1.1",
    "@ditadi/qwik-hooks": "^0.1.6",
    "@eslint/js": "^10.0.1",
    "@modular-forms/qwik": "^0.29.1",
    "@playwright/test": "^1.61.1",
    "@qwikest/icons": "latest",
    "@tailwindcss/typography": "latest",
    "@tailwindcss/vite": "^4.3.2",
    "@types/bun": "^1.3.14",
    "@types/eslint": "^9.6.1",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@unpic/qwik": "v1.0.0",
    "autoprefixer": "^10.5.2",
    "daisyui": "^5.6.16",
    "eslint": "^10.6.0",
    "eslint-plugin-qwik": "^1.20.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "qwik-theme-toggle": "^2.1.0",
    "qwik-toasts": "^2.0.2",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "^7.3.6",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
