# Local development only. Keep real values in .env, GitHub environments, or
# Google Secret Manager.

AUTH_URL="http://localhost:5173"
AUTH_SECRET="replace-with-a-long-random-local-secret"
TRUSTED_ORIGINS=""

GOOGLE_ID="your-google-oauth-client-id"
GOOGLE_SECRET="your-google-oauth-client-secret"

MONGO_URI="mongodb+srv://user:password@example.mongodb.net/movies"
TMDB_API_KEY="your-tmdb-api-key"
GC_API_KEY="your-cloud-gateway-api-key"

JACRED_API_BASE_URL="http://127.0.0.1:9117"
JACRED_SEARCH_PATH="/api/v1.0/indexers/all/results/torznab/api"
JACRED_SEARCH_LIMIT="100"
JACRED_SEARCH_TIMEOUT_MS="15000"
